{
  "manifest_version": 3,
  "name": "AI Tone Changer",
  "version": "1.0.4",
  "description": "Convert your text to professional or casual English using AI",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "commands": {
    "toggle-tone-menu": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Toggle AI Tone Changer menu"
    }
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AI Tone Changer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-tone-changer@baik.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
